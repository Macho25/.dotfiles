set $m1 DP-4
set $m2 HDMI-0
set $mod  Mod4
set $mod2 Mod5

include $HOME/.config/i3/autostart.conf
include $HOME/.config/i3/workspaces.conf
include $HOME/.config/i3/keybindings.conf
include $HOME/.config/i3/window.conf
include $HOME/.config/i3/colors.conf
include $HOME/.config/i3/spotify.conf
include $HOME/.config/i3/custom_keybinds.conf

exec --no-startup-id xrandr --output $m1 --mode 1920x1080

font pango: Noto Sans Regular 10

exec --no-startup-id sleep 1 && wallpaper 

exec --no-startup-id sleep 0.5 && i3-msg restart
exec --no-startup-id sleep 0.5 && i3-msg restart 

exec --no-startup-id sleep 2 && ~/.config/i3/startup_firefox.sh

exec --no-startup-id sleep 1 && wallpaper 

